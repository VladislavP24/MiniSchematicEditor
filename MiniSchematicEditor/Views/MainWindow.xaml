<Window x:Class="MiniSchematicEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MiniSchematicEditor" xmlns:models="clr-namespace:MiniSchematicEditor.Models"
        xmlns:converters="clr-namespace:MiniSchematicEditor.Converters"
        mc:Ignorable="d"
        Title="Мини-редактор схемы" 
        Height="450" Width="800"
        MinHeight="450" MinWidth="800">

    <Window.Resources>
        <ResourceDictionary>
            <!--Подключение стилей-->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MiniSchematicEditor;component/Styles/ButtonPanelStyles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MiniSchematicEditor;component/Styles/BlockTemplatesStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!--Сообщение о ошибки валидации в виде подсказки-->
            <Style TargetType="TextBox">
                <Style.Triggers>
                    <Trigger Property="Validation.HasError" Value="true">
                        <Setter Property="ToolTip" 
                    Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)/ErrorContent}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <!--Подключение конвертера-->
            <converters:EqualsConverter x:Key="EqualsConverter"/>
        </ResourceDictionary>
    </Window.Resources>
    
    <Border Background="#1E1E1E">
        <Grid Cursor="">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="15"/>
            </Grid.RowDefinitions>

            <!--Верхняя панель меню-->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Новый проект"
                            Command="{Binding CreateNewProject}"
                            Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Открыть проект"
                            Command="{Binding OpenProject}"
                            Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Сохранить проект"
                            Command="{Binding SaveProject}"
                            Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Добавить элемент"
                            Command="{Binding AddBlock}"
                            Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <!--Рабочая область-->
                <Border Grid.Column="0" BorderThickness="0,0,2,0" BorderBrush="White">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Background="White" Orientation="Horizontal">
                            <TextBlock Text="Рабочая область проекта:"
                                       Margin="10,0,0,0"
                                       Foreground="Black"
                                       FontSize="14"/>
                            <TextBlock Text = "{Binding ProjectName, Mode=OneWay, TargetNullValue=''}"
                                       Margin="10,0,0,0"
                                       Foreground="Black"
                                       FontSize="14"/>
                        </StackPanel>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Blocks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Background="#252526" ClipToBounds="True" IsItemsHost="True"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X, Mode=TwoWay}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y, Mode=TwoWay}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!--Боковая панель-->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!--Информация о блоке-->
                    <Grid Grid.Row="0" Background="White">
                        <TextBlock Text="Информация о блоке"
                                       Foreground="Black"
                                       HorizontalAlignment="Center"
                                       FontSize="14"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="20,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="UID:"
                                       Width="110"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       FontSize="14"/>
                            <TextBox Text="{Binding SelectedBlock.UId, Mode=OneWay, TargetNullValue='-'}"
                                     IsReadOnly="True"
                                     Width="180"
                                     HorizontalAlignment="Center"
                                     FontSize="14"
                                     Margin="20,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Имя:"
                                       Width="110"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       FontSize="14"/>
                            <TextBox Text="{Binding SelectedBlock.Name, UpdateSourceTrigger=PropertyChanged, TargetNullValue='-', ValidatesOnNotifyDataErrors=True}"
                                     Width="180"
                                     HorizontalAlignment="Center"
                                     FontSize="14"
                                     Margin="20,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Тип:"
                                       Width="110"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       FontSize="14"/>
                            <ComboBox ItemsSource="{Binding AllBlockTypes, UpdateSourceTrigger=PropertyChanged, TargetNullValue='-'}"
                                      SelectedItem="{Binding SelectedBlock.Type, Mode=TwoWay}"
                                      Width="180"
                                      HorizontalAlignment="Center"
                                      FontSize="14"
                                      Margin="20,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Координаты X/Y:"
                                       Width="110"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       FontSize="14"/>
                            <TextBox Text="{Binding SelectedBlock.X, UpdateSourceTrigger=PropertyChanged, TargetNullValue='0', FallbackValue='0', ValidatesOnNotifyDataErrors=True}"
                                     Width="80"
                                     HorizontalAlignment="Center"
                                     FontSize="14"
                                     Margin="20,0,0,0"
                                     PreviewTextInput="XCoordinate_PreviewTextInput"/>
                            <TextBox Text="{Binding SelectedBlock.Y, UpdateSourceTrigger=PropertyChanged, TargetNullValue='0', FallbackValue='0', ValidatesOnNotifyDataErrors=True}"
                                     Width="80"
                                     HorizontalAlignment="Center"
                                     FontSize="14"
                                     Margin="20,0,0,0"
                                     PreviewTextInput="YCoordinate_PreviewTextInput"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Состояние:"
                                       Width="110"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       FontSize="14"/>
                            <CheckBox IsChecked="{Binding SelectedBlock.IsActive, UpdateSourceTrigger=PropertyChanged}" 
                                      Content="{Binding SelectedBlock.StatusText}" 
                                      Foreground="White" 
                                      FontSize="14" 
                                      VerticalAlignment="Center" 
                                      Margin="20,0,0,0"/>
                        </StackPanel>
                        <Button Content="Удалить элемент"
                                Command="{Binding RemoveBlock}"
                                Style="{StaticResource MenuButtonStyle}"/>
                    </StackPanel>

                    <!--Список блоков на рабочей области-->
                    <Grid Grid.Row="2" Background="White">
                        <TextBlock Text="Список блоков"
                                       Foreground="Black"
                                       HorizontalAlignment="Center"
                                       FontSize="14"/>
                    </Grid>

                    <ListBox Grid.Row="3"
                             Background="#1E1E1E"
                             Foreground="White"
                             BorderThickness="0"
                             ItemsSource="{Binding Blocks}"
                             SelectedItem="{Binding SelectedBlock, Mode=TwoWay}"
                             DisplayMemberPath="Name"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Background="White"/>
        </Grid>
    </Border>
</Window>
