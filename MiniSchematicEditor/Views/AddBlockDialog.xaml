<Window x:Class="MiniSchematicEditor.Views.AddBlockDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MiniSchematicEditor.Views"
        mc:Ignorable="d"
        Title="AddBlockDialog"     
        Height="250" Width="350"
        MinHeight="250" MinWidth="350"
        MaxHeight="250" MaxWidth="350">

    <Window.Resources>
        <ResourceDictionary>
            <!--Подключение стилей-->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MiniSchematicEditor;component/Styles/ButtonPanelStyles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MiniSchematicEditor;component/Styles/ComboBoxStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!--Сообщение о ошибки валидации в виде подсказки-->
            <Style TargetType="TextBox">
                <Style.Triggers>
                    <Trigger Property="Validation.HasError" Value="true">
                        <Setter Property="ToolTip" 
                                Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)/ErrorContent}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Введите значения для нового блока:"
                   FontSize="14"
                   Margin="0,0,0,10"/>

        <!--Имя-->
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <TextBlock Text="Имя:"
                       Width="110"
                       Foreground="Black"
                       HorizontalAlignment="Center"
                       FontSize="14"
                       Margin="0,2"
                       VerticalAlignment="Center"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                     Foreground="White"
                     Background="#1E1E1E"
                     FontSize="12"
                     Width="180"
                     Margin="0,2"
                     VerticalContentAlignment="Center"/>
        </StackPanel>
        <!--Тип-->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock Text="Тип:"
                       Width="110"
                       Foreground="Black"
                       HorizontalAlignment="Center"
                       FontSize="14"
                       Margin="0,2"
                       VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding AllBlockTypes, UpdateSourceTrigger=PropertyChanged}"
                      SelectedItem="{Binding SelectedType, Mode=TwoWay}"
                      Width="180"
                      HorizontalAlignment="Center"
                      FontSize="14"
                      Margin="0,2"
                      Background="Black"
                      Foreground="White"
                      Style="{StaticResource InvertedComboBox}"/>
        </StackPanel>
        <!--Координаты-->
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <TextBlock Text="Координаты X/Y:"
                       Width="110"
                       Foreground="Black"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Margin="0,2"/>
            <TextBox Text="{Binding X, UpdateSourceTrigger=PropertyChanged, TargetNullValue='0', ValidatesOnNotifyDataErrors=True}"
                     Foreground="White"
                     Background="#1E1E1E"
                     FontSize="12"
                     Width="80"
                     VerticalContentAlignment="Center"
                     PreviewTextInput="XCoordinate_PreviewTextInput"/>
            <TextBox Text="{Binding Y, UpdateSourceTrigger=PropertyChanged, TargetNullValue='0', ValidatesOnNotifyDataErrors=True}"
                     Foreground="White"
                     Background="#1E1E1E"
                     FontSize="12"
                     Width="80"
                     VerticalContentAlignment="Center"
                     Margin="20,0,0,0"
                     PreviewTextInput="YCoordinate_PreviewTextInput"/>
        </StackPanel>

        <!--Кнопки ОК/Отмена-->
        <StackPanel Grid.Row="4" 
                Orientation="Horizontal" 
                HorizontalAlignment="Right"
                Margin="0,5,0,0">
            <Button Content="Ок"
                Command="{Binding Ok}"
                Foreground="Black"
                Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="Отмена"
                Command="{Binding Cancel}"
                Foreground="Black"
                Style="{StaticResource MenuButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
