<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:MiniSchematicEditor.Models"
                    xmlns:converters="clr-namespace:MiniSchematicEditor.Converters">

    <DataTemplate DataType="{x:Type models:BlockModel}">
        <!--Сам элемент блока-->
        <Grid Width="60" Height="60" x:Name="ShapeGrid">
            <Grid.InputBindings>
                <MouseBinding MouseAction="LeftClick" 
                              Command="{Binding DataContext.SelectBlock, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding Path=.}"/>
            </Grid.InputBindings>
            <Path x:Name="ShapeVisual" Fill="#333337">
                <Path.Data>
                    <RectangleGeometry Rect="0,0,60,60"/>
                </Path.Data>
                <Path.Style>
                    <Style TargetType="Path">
                        <Setter Property="Stroke" Value="CornflowerBlue"/>
                        <Setter Property="StrokeThickness" Value="2"/>
                    </Style>
                </Path.Style>
            </Path>

            <!--Текст с именем блока по центру-->
            <TextBlock Text="{Binding Name}" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       FontSize="11"/>
        </Grid>

        <!--Триггеры для управления переключением форм и цветов-->
        <DataTemplate.Triggers>
            <!--Если тип КРУГ — меняем геометрию Path и цвет рамки-->
            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:BlockType.Circle}">
                <Setter TargetName="ShapeVisual" Property="Data">
                    <Setter.Value>
                        <EllipseGeometry Center="30,30" RadiusX="30" RadiusY="30"/>
                    </Setter.Value>
                </Setter>
                <Setter TargetName="ShapeVisual" Property="Style">
                    <Setter.Value>
                        <Style TargetType="Path">
                            <Setter Property="Stroke" Value="Tomato"/>
                            <Setter Property="StrokeThickness" Value="2"/>
                        </Style>
                    </Setter.Value>
                </Setter>
            </DataTrigger>

            <!--Если тип РОМБ — меняем геометрию Path на ромб-->
            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:BlockType.Rhombus}">
                <Setter TargetName="ShapeVisual" Property="Data" Value="M 30,0 L 60,30 L 30,60 L 0,30 Z"/>
                <Setter TargetName="ShapeVisual" Property="Style">
                    <Setter.Value>
                        <Style TargetType="Path">
                            <Setter Property="Stroke" Value="MediumSeaGreen"/>
                            <Setter Property="StrokeThickness" Value="2"/>
                        </Style>
                    </Setter.Value>
                </Setter>
            </DataTrigger>

            <!--Триггеры для подсветки-->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsActive}" Value="True"/>
                    <Condition Value="True">
                        <Condition.Binding>
                            <MultiBinding Converter="{converters:EqualsConverter}">
                                <Binding Path="DataContext.SelectedBlock" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                <Binding Path="."/>
                            </MultiBinding>
                        </Condition.Binding>
                    </Condition>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="ShapeVisual" Property="Stroke" Value="#FFD700"/>
                <Setter TargetName="ShapeVisual" Property="StrokeThickness" Value="3"/>
            </MultiDataTrigger>

            <!--Триггер на Active/Disable-->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsActive}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="ShapeGrid" Property="Opacity" Value="0.4"/>
                <Setter TargetName="ShapeVisual" Property="Stroke" Value="Gray"/>
                <Setter TargetName="ShapeVisual" Property="StrokeThickness" Value="2"/>
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>
    
</ResourceDictionary>